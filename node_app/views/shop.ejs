<%- include('header') %>
<main class="main-content">
<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h1 class="section-title mb-0">Browse the Collection</h1>
            <p class="text-muted small mt-1"><%= songs.length %> song(s) found</p>
        </div>
        <form action="/shop" method="GET" class="d-flex gap-2">
            <input type="text" name="q" class="form-control" placeholder="Search songs…" value="<%= q %>">
            <button type="submit" class="btn btn-primary">Go</button>
        </form>
    </div>

    <% if (songs.length === 0) { %>
        <div class="empty-state"><h4>No songs found</h4></div>
    <% } else { %>
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            <% songs.forEach(function(song) { %>
            <div class="col">
                <div class="song-card">
                    <div class="song-card-img">
                        <i class="bi bi-music-note-beamed music-icon"></i>
                        <span class="format-badge"><%= song.available_as %></span>
                    </div>
                    <div class="song-card-body">
                        <div class="song-title"><%= song.title %></div>
                        <div class="song-movie"><i class="bi bi-film"></i> <%= song.movie_name %></div>
                        <div class="song-singer"><i class="bi bi-mic"></i> <%= song.singers || '—' %></div>
                    </div>
                    <div class="song-card-footer">
                        <span class="price-tag"><%= formatPrice(song.price) %></span>
                        <a href="/song/<%= song.song_id %>" class="btn btn-buy btn-sm">View</a>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    <% } %>
</div>
</main>
<%- include('footer') %>
