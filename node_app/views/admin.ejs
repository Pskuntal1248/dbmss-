<%- include('header') %>
<main class="main-content">
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Admin Dashboard</h1>
        <a href="/admin/add-song" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i> Add New Song</a>
    </div>
    <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
        <div class="col"><div class="stat-card"><div class="stat-val"><%= stats.songs %></div><div class="stat-lbl">Songs</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-val"><%= stats.singers %></div><div class="stat-lbl">Singers</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-val"><%= stats.customers %></div><div class="stat-lbl">Customers</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-val">₹<%= stats.revenue %></div><div class="stat-lbl">Revenue</div></div></div>
    </div>
    <div class="admin-card">
        <h5 class="fw-bold mb-3">Recent Purchases</h5>
        <table class="table">
            <thead><tr><th>#</th><th>Customer</th><th>Song</th><th>Amount</th></tr></thead>
            <tbody>
            <% recent.forEach(function(r) { %>
                <tr><td><%= r.purchase_id %></td><td><%= r.username %></td><td><%= r.song_title %></td><td>₹<%= r.amount_paid %></td></tr>
            <% }); %>
            </tbody>
        </table>
    </div>
</div>
</main>
<%- include('footer') %>
