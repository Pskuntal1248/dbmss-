<%- include('header') %>
<main class="main-content">
<div class="container py-5">
    <% if (flash) { %>
        <div class="alert alert-info"><%= flash %></div>
    <% } %>
    <div class="row g-5">
        <div class="col-lg-8">
            <div class="detail-hero mb-4">
                <div class="d-flex align-items-start gap-4 flex-wrap">
                    <div style="width:80px;height:80px;background:linear-gradient(135deg,#7c3aed,#a78bfa);border-radius:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="bi bi-music-note-beamed text-white" style="font-size:2.2rem"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h1 class="fw-bold mb-1"><%= song.title %></h1>
                        <p class="text-muted"><i class="bi bi-film me-1"></i><strong>Movie:</strong> <%= song.movie_name %></p>
                    </div>
                    <div class="detail-price"><%= formatPrice(song.price) %></div>
                </div>
            </div>
            <div class="info-grid">
                <div class="info-card"><div class="label">Singer(s)</div><div class="value"><%= song.singers || '—' %></div></div>
                <div class="info-card"><div class="label">Composer(s)</div><div class="value"><%= song.composers || '—' %></div></div>
                <div class="info-card"><div class="label">Label</div><div class="value"><%= song.company_name %></div></div>
                <div class="info-card"><div class="label">Duration</div><div class="value"><%= song.duration %></div></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-card">
                <h5 class="fw-bold mb-3"><i class="bi bi-cart me-2"></i>Purchase Song</h5>
                <% if (alreadyOwned) { %>
                    <div class="text-center py-3"><i class="bi bi-check-circle-fill text-success fs-2 d-block mb-2"></i><p>You own this song!</p></div>
                <% } else if (!user) { %>
                    <a href="/login" class="btn btn-primary w-100">Login to Buy</a>
                <% } else { %>
                    <form method="POST">
                        <input type="hidden" name="buy" value="1">
                        <button type="submit" class="btn btn-buy w-100 py-2">Buy Now - <%= formatPrice(song.price) %></button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</div>
</main>
<%- include('footer') %>
